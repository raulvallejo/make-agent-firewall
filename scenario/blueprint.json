                                "content": "<h3 style=\"color:#e65c00\">⚠️ Agent Firewall — Message Flagged for Review</h3>\n\n<table style=\"font-family:sans-serif;font-size:14px;border-collapse:collapse;width:100%\">\n  <tr>\n    <td style=\"padding:8px;color:#666;width:160px\">Threat detected</td>\n    <td style=\"padding:8px;font-weight:bold\">{{5.threat_detected}}</td>\n  </tr>\n  <tr style=\"background:#f9f9f9\">\n    <td style=\"padding:8px;color:#666\">OWASP ref</td>\n    <td style=\"padding:8px\">{{5.owasp_ref}}</td>\n  </tr>\n  <tr>\n    <td style=\"padding:8px;color:#666\">Confidence</td>\n    <td style=\"padding:8px\">{{5.confidence}}</td>\n  </tr>\n  <tr style=\"background:#f9f9f9\">\n    <td style=\"padding:8px;color:#666\">Reason</td>\n    <td style=\"padding:8px\">{{5.reason}}</td>\n  </tr>\n  <tr>\n    <td style=\"padding:8px;color:#666\">Original message</td>\n    <td style=\"padding:8px;color:#c0392b\">{{5.sanitized_input}}</td>\n  </tr>\n  <tr style=\"background:#f9f9f9\">\n    <td style=\"padding:8px;color:#666\">Recommended action</td>\n    <td style=\"padding:8px\">{{5.recommended_action}}</td>\n  </tr>\n</table>",
                                "subject": "Agent Firewall - Review Required",
                                "bodyType": "rawHtml"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 1200,
                                    "y": 300,
                                    "name": "Alert - Flag for Review"
                                },
                                "restore": {
                                    "expect": {
                                        "cc": {
                                            "mode": "chose"
                                        },
                                        "to": {
                                            "mode": "chose",
                                            "items": [
                                                null
                                            ]
